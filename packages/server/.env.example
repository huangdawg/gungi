# Database — Postgres connection string. Local: docker-postgres. Prod: Neon pooled URL.
DATABASE_URL=postgresql://postgres:password@localhost:5432/gungi

# Server
PORT=3001
NODE_ENV=development

# Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# Public origin of THIS server (used by better-auth for cookie domain + share links).
# Local: http://localhost:3001. Prod: https://gungi-server.up.railway.app
BASE_URL=http://localhost:3001

# Allowed client origins for CORS — comma-separated, no trailing slashes.
# Local: http://localhost:5173
# Prod example: http://localhost:5173,https://gungi.vercel.app
CLIENT_URL=http://localhost:5173
